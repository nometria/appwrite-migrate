{
  "$id": "user_profiles",
  "name": "User Profiles",
  "documentSecurity": true,
  "attributes": [
    {
      "key": "displayName",
      "type": "string",
      "size": 128,
      "required": true,
      "default": null,
      "array": false
    },
    {
      "key": "email",
      "type": "email",
      "required": true,
      "default": null,
      "array": false
    },
    {
      "key": "avatarUrl",
      "type": "url",
      "required": false,
      "default": null,
      "array": false
    },
    {
      "key": "bio",
      "type": "string",
      "size": 500,
      "required": false,
      "default": null,
      "array": false
    },
    {
      "key": "role",
      "type": "string",
      "size": 50,
      "required": true,
      "default": "member",
      "array": false
    },
    {
      "key": "plan",
      "type": "string",
      "size": 30,
      "required": false,
      "default": "free",
      "array": false
    },
    {
      "key": "onboardingComplete",
      "type": "boolean",
      "required": false,
      "default": false,
      "array": false
    },
    {
      "key": "lastLoginAt",
      "type": "datetime",
      "required": false,
      "default": null,
      "array": false
    }
  ],
  "indexes": [
    {
      "key": "email_unique",
      "type": "unique",
      "attributes": ["email"],
      "orders": ["ASC"]
    },
    {
      "key": "role_idx",
      "type": "key",
      "attributes": ["role"],
      "orders": ["ASC"]
    }
  ]
}
